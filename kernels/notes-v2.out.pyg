\PYG{c+cp}{        \PYGZdq{} \PYGZpc{}16,  \PYGZpc{}17,  \PYGZpc{}18,  \PYGZpc{}19,  \PYGZpc{}20,  \PYGZpc{}21,  \PYGZpc{}22,  \PYGZpc{}23,  \PYGZdq{}                    \PYGZbs{}}
