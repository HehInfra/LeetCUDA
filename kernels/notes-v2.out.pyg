\PYG{+w}{  }\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{s\PYGZus{}a}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{smem}\PYG{p}{;}
\PYG{+w}{  }\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{s\PYGZus{}b}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{smem}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{K\PYGZus{}STAGE}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{BM}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{BK}\PYG{p}{;}\PYG{+w}{     }\PYG{c+c1}{// A 和 B 连续存放}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{s\PYGZus{}a\PYGZus{}stage\PYGZus{}offset}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{BM}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{BK}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 128*16}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{s\PYGZus{}b\PYGZus{}stage\PYGZus{}offset}\PYG{+w}{ }\PYG{o}{=}
\PYG{+w}{      }\PYG{n}{BN}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{BK}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 128*16  ⚠ BN(128)×BK(16) = B\PYGZca{}T row\PYGZhy{}major 的 smem 布局}

\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{tid}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{threadIdx}\PYG{p}{.}\PYG{n}{y}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{blockDim}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{threadIdx}\PYG{p}{.}\PYG{n}{x}\PYG{p}{;}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}id}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{tid}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 0\PYGZti{}7}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{lane\PYGZus{}id}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{tid}\PYG{+w}{ }\PYG{o}{\PYGZpc{}}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 0\PYGZti{}31}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}m}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}id}\PYG{+w}{ }\PYG{o}{\PYGZpc{}}\PYG{+w}{ }\PYG{l+m+mi}{2}\PYG{p}{;}\PYG{+w}{      }\PYG{c+c1}{// 0,1（M 方向 2 个 warp）}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}n}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}id}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{l+m+mi}{2}\PYG{p}{;}\PYG{+w}{      }\PYG{c+c1}{// 0,1,2,3（N 方向 4 个 warp）}

\PYG{+w}{  }\PYG{c+c1}{// 线程到 global memory 的映射（用于加载 A 和 B）}
\PYG{+w}{  }\PYG{c+c1}{// TN 布局关键: A[m*K+k] 是 row\PYGZhy{}major, B\PYGZca{}T[n*K+k] 是 row\PYGZhy{}major（内维连续的是 K）}
