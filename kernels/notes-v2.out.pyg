\PYG{+w}{    }\PYG{n}{shared}\PYG{p}{[}\PYG{n}{warp}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{value}\PYG{p}{;}
