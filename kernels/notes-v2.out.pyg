\PYG{c+cp}{      : \PYGZdq{}=r\PYGZdq{}(R0), \PYGZdq{}=r\PYGZdq{}(R1)                                                     \PYGZbs{}}
\PYG{c+cp}{      : \PYGZdq{}r\PYGZdq{}(addr))}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} mma.sync.aligned.m16n8k16.row.col.f16.f16.f16.f16 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// m16n8k16: M=16, N=8, K=16（Ampere Tensor Core 的基本 tile）}
\PYG{c+c1}{// row.col: A 是 row\PYGZhy{}major, B 是 col\PYGZhy{}major}
\PYG{c+c1}{// f16.f16.f16.f16: A/B 是 f16, C/D 是 f16（f32 累加版本用 f32.f16.f16.f32）}
\PYG{c+c1}{// 2 个输出寄存器（RD0, RD1），4 个 A 寄存器 + 2 个 B 寄存器}
\PYG{c+c1}{// C 矩阵大小 16×8=128 元素 = 128 个 half；32 线程分担，每线程 4 half = 2 个 uint32}
\PYG{c+cp}{\PYGZsh{}define HMMA16816(RD0, RD1, RA0, RA1, RA2, RA3, RB0, RB1, RC0, RC1)            \PYGZbs{}}
\PYG{c+cp}{  asm volatile(                                                                \PYGZbs{}}
\PYG{c+cp}{      \PYGZdq{}mma.sync.aligned.m16n8k16.row.col.f16.f16.f16.f16 \PYGZob{}\PYGZpc{}0, \PYGZpc{}1\PYGZcb{}, \PYGZob{}\PYGZpc{}2, \PYGZpc{}3, \PYGZdq{}  \PYGZbs{}}
\PYG{c+cp}{      \PYGZdq{}\PYGZpc{}4, \PYGZpc{}5\PYGZcb{}, \PYGZob{}\PYGZpc{}6, \PYGZpc{}7\PYGZcb{}, \PYGZob{}\PYGZpc{}8, \PYGZpc{}9\PYGZcb{};\PYGZbs{}n\PYGZdq{}                                         \PYGZbs{}}
\PYG{c+cp}{      : \PYGZdq{}=r\PYGZdq{}(RD0), \PYGZdq{}=r\PYGZdq{}(RD1)                                                   \PYGZbs{}}
\PYG{c+cp}{      : \PYGZdq{}r\PYGZdq{}(RA0), \PYGZdq{}r\PYGZdq{}(RA1), \PYGZdq{}r\PYGZdq{}(RA2), \PYGZdq{}r\PYGZdq{}(RA3), \PYGZdq{}r\PYGZdq{}(RB0), \PYGZdq{}r\PYGZdq{}(RB1), \PYGZdq{}r\PYGZdq{}(RC0),  \PYGZbs{}}
\PYG{c+cp}{        \PYGZdq{}r\PYGZdq{}(RC1))}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} MMA 辅助函数 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// div\PYGZus{}ceil: 整数除法向上取整}
\PYG{c+cp}{\PYGZsh{}define HOST\PYGZus{}DEVICE\PYGZus{}INLINE \PYGZus{}\PYGZus{}device\PYGZus{}\PYGZus{} \PYGZus{}\PYGZus{}host\PYGZus{}\PYGZus{} inline}
