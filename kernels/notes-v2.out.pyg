\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 9: FlashAttention\PYGZhy{}2 (Split\PYGZhy{}Q + MMA m16n8k16)}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点（FlashAttention 算法）：}
\PYG{c+c1}{//   1. 核心问题：标准 Attention 的 O(N\PYGZca{}2) 中间矩阵 (S=QK\PYGZca{}T) 必须写入 HBM，}
\PYG{c+c1}{//      但 HBM 带宽是瓶颈 → FlashAttention 用 tiling + online softmax 避免写回}
\PYG{c+c1}{//   2. FA 三板斧：}
\PYG{c+c1}{//      a) Tiling: Q 分块 [Br,d]，K/V 沿 seqlen 分块 [Bc,d]}
\PYG{c+c1}{//      b) Online Softmax: 迭代更新 m(行max) 和 l(行sum)，无需全局同步}
\PYG{c+c1}{//      c) Recomputation(反向): 反向传播时重新计算 S/P，而非存储中间矩阵}
\PYG{c+c1}{//   3. Split\PYGZhy{}Q 设计: 所有 warp 共享同一块 K，各 warp 处理 Q 的不同行片段}
\PYG{c+c1}{//      \PYGZhy{} warp\PYGZus{}KV=0（所有 warp 共享 K），warp\PYGZus{}QP=warp\PYGZus{}id（各 warp 不同 Q 行）}
\PYG{c+c1}{//      \PYGZhy{} 优点：减少 warp 间通信和 shuffle}
\PYG{c+c1}{//   4. Online rescaling 公式（FA 核心，arXiv:2307.08691）：}
\PYG{c+c1}{//      for each K,V tile:}
\PYG{c+c1}{//        S\PYGZus{}cur = Q @ K\PYGZca{}T                         // 未缩放，存入 R\PYGZus{}S}
\PYG{c+c1}{//        m\PYGZus{}new = max(m\PYGZus{}old, row\PYGZus{}max(S\PYGZus{}cur * scale))}
\PYG{c+c1}{//        P\PYGZus{}cur = exp(S\PYGZus{}cur * scale \PYGZhy{} m\PYGZus{}new)      // ← 写回 R\PYGZus{}S 寄存器！}
\PYG{c+c1}{//        l\PYGZus{}new = exp(m\PYGZus{}old \PYGZhy{} m\PYGZus{}new) * l\PYGZus{}old + row\PYGZus{}sum(P\PYGZus{}cur)}
\PYG{c+c1}{//        O\PYGZus{}new = diag(exp(m\PYGZus{}old \PYGZhy{} m\PYGZus{}new)) * O\PYGZus{}old + P\PYGZus{}cur @ V}
\PYG{c+c1}{//      O\PYGZus{}final = O\PYGZus{}new / l\PYGZus{}final}
\PYG{c+c1}{//   5. 为什么 R\PYGZus{}S 可以直接用作 P@V 的 A 矩阵？}
\PYG{c+c1}{//      \PYGZhy{} R\PYGZus{}S 经过 softmax 后，存储的是 P = exp(S \PYGZhy{} m)，数据仍然是 half 精度}
\PYG{c+c1}{//      \PYGZhy{} 当前实现依赖 m16n8k16 这一路径下约定好的 fragment 布局，使 softmax}
\PYG{c+c1}{//        后的 P 可以继续留在 R\PYGZus{}S 中供后面的 P@V 直接消费}
\PYG{c+c1}{//      \PYGZhy{} 这是此实现的寄存器布局复用技巧，不要背成“所有 MMA A/C fragment}
\PYG{c+c1}{//        都天然同构”的通用结论}
\PYG{c+c1}{//}
\PYG{c+c1}{// 本实现参考: FlashAttention\PYGZhy{}2 (Dao et al., arXiv:2307.08691)}
\PYG{c+c1}{// 从 LeetCUDA flash\PYGZhy{}attn/mma/basic/flash\PYGZus{}attn\PYGZus{}mma\PYGZus{}split\PYGZus{}q.cu 提取}
\PYG{c+c1}{// Grid:  ((QKV\PYGZus{}seqlen + 63) / 64, QKV\PYGZus{}batch * QKV\PYGZus{}head, 1)，Br=64}
\PYG{c+c1}{// Block: (128, 1, 1)，kNumThreads=WARP\PYGZus{}SIZE×kMmaTileSeqLenQ×kMmaTileSeqLenK=128}
\PYG{c+c1}{// source: LeetCUDA/kernels/flash\PYGZhy{}attn/mma/basic/flash\PYGZus{}attn\PYGZus{}mma\PYGZus{}split\PYGZus{}q.cu}

