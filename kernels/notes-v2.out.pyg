\PYG{+w}{  }\PYG{k}{return}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{a}\PYG{+w}{ }\PYG{o}{\PYGZpc{}}\PYG{+w}{ }\PYG{n}{b}\PYG{+w}{ }\PYG{o}{!=}\PYG{+w}{ }\PYG{l+m+mi}{0}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{?}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{a}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{n}{b}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{:}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{a}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{n}{b}\PYG{p}{);}
\PYG{p}{\PYGZcb{}}

\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 5b\PYGZhy{}2: HGEMM MMA — m16n8k16 + multistage pipeline + TN 布局}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试重点 — Tile Hierarchy:}
\PYG{c+c1}{//   MMA Atom:         m16n8k16（1 条 MMA 指令处理的最小 tile）}
\PYG{c+c1}{//   MMA Tile (warp):  2×4=8 个 MMA atom = [32×32]（一个 warp 的计算）}
\PYG{c+c1}{//   Warp Tile:        4×4=16 warps = [128×128]（整个 block 的计算）}
\PYG{c+c1}{//   线程映射:         2×4=8 warps, 每个 warp 4×1=4 个 warp tile}
\PYG{c+c1}{// 实际: MMA\PYGZus{}TILE\PYGZus{}M=2, MMA\PYGZus{}TILE\PYGZus{}N=4, WARP\PYGZus{}TILE\PYGZus{}M=4, WARP\PYGZus{}TILE\PYGZus{}N=4}
\PYG{c+c1}{//       → BM=16×2×4=128, BN=8×4×4=128, Warps=2×4=8, Threads=8×32=256}
\PYG{c+c1}{//}
\PYG{c+c1}{// TN 布局在本 kernel 中的体现（T=A 行优先，N=B 列优先）：}
\PYG{c+c1}{//   \PYGZhy{} A[M][K]: row\PYGZhy{}major, 全局索引 A[m*K + k], shared memory s\PYGZus{}a[BM][BK]}
\PYG{c+c1}{//   \PYGZhy{} B[K][N]: col\PYGZhy{}major（等价于 B\PYGZca{}T[N][K] row\PYGZhy{}major）, 全局索引 B[n*K+k] 即原 B 元素 (k,n)}
\PYG{c+c1}{//              （⚠ 内维连续的是 K）shared memory s\PYGZus{}b[BN][BK] = s\PYGZus{}b[N\PYGZus{}tile][K\PYGZus{}tile]}
\PYG{c+c1}{//   \PYGZhy{} ldmatrix A: 用 x4（非转置），因为 A 是 row\PYGZhy{}major，ldmatrix 原生匹配}
\PYG{c+c1}{//   \PYGZhy{} ldmatrix B: 用 x2（非转置），因为 B\PYGZca{}T 在 smem 中为 row\PYGZhy{}major，ldmatrix 逐行加载}
\PYG{c+c1}{//     B\PYGZca{}T 的行即 B 的列，天然匹配 MMA row.col 的 col\PYGZhy{}major B 输入，无需 .trans}
\PYG{c+c1}{//   \PYGZhy{} MMA 指令: row.col = A row, B col → 天然匹配 TN 布局}
\PYG{c+c1}{// Grid:  ((N+127)/128/S, (M+127)/128, S)，S=(N+2047)/2048，3D block swizzle}
\PYG{c+c1}{//   \PYGZhy{} grid.z = S 个 swizzle 分区}
\PYG{c+c1}{//   \PYGZhy{} grid.x = 每个分区内部需要发射多少个 128x128 的 N tiles}
\PYG{c+c1}{//   \PYGZhy{} bx = blockIdx.z * gridDim.x + blockIdx.x，把连续 block 打散到不同 N 区域，改善 L2 命中}
\PYG{c+c1}{// Block: (256, 1, 1)，8 warps}
\PYG{c+c1}{// source: LeetCUDA/kernels/hgemm/mma/basic/hgemm\PYGZus{}mma\PYGZus{}stage\PYGZus{}tn.cu}
\PYG{k}{template}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}M}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{16}\PYG{p}{,}\PYG{+w}{ }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}N}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{8}\PYG{p}{,}\PYG{+w}{ }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}K}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{16}\PYG{p}{,}
\PYG{+w}{          }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}TILE\PYGZus{}M}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{2}\PYG{p}{,}\PYG{+w}{ }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}TILE\PYGZus{}N}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{4}\PYG{p}{,}
\PYG{+w}{          }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}TILE\PYGZus{}M}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{4}\PYG{p}{,}\PYG{+w}{ }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}TILE\PYGZus{}N}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{4}\PYG{p}{,}
\PYG{+w}{          }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{K\PYGZus{}STAGE}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{3}\PYG{p}{,}\PYG{+w}{ }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{bool}\PYG{+w}{ }\PYG{n}{BLOCK\PYGZus{}SWIZZLE}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n+nb}{false}\PYG{o}{\PYGZgt{}}
\PYG{n}{\PYGZus{}\PYGZus{}global\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{k+kt}{void}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}launch\PYGZus{}bounds\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{l+m+mi}{256}\PYG{p}{)}
\PYG{+w}{    }\PYG{n}{hgemm\PYGZus{}mma\PYGZus{}stages\PYGZus{}tn}\PYG{p}{(}\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{A}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{B}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{C}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{M}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{N}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{K}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{  }\PYG{c+c1}{// Block Swizzle: 在 grid x 维度做 swizzle，改善 L2 cache 局部性}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{bx}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{p}{((}\PYG{k+kt}{int}\PYG{p}{)}\PYG{n}{BLOCK\PYGZus{}SWIZZLE}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{blockIdx}\PYG{p}{.}\PYG{n}{z}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{gridDim}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{blockIdx}\PYG{p}{.}\PYG{n}{x}\PYG{p}{;}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{by}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{blockIdx}\PYG{p}{.}\PYG{n}{y}\PYG{p}{;}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{BM}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}M}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}TILE\PYGZus{}M}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}TILE\PYGZus{}M}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 16*2*4=128}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{BN}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}N}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}TILE\PYGZus{}N}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}TILE\PYGZus{}N}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 8*4*4=128}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{BK}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{MMA\PYGZus{}K}\PYG{p}{;}\PYG{+w}{                            }\PYG{c+c1}{// 16}

\PYG{+w}{  }\PYG{c+c1}{// Dynamic shared memory: K\PYGZus{}STAGE 个 stage 的 A 和 B}
\PYG{+w}{  }\PYG{c+c1}{// TN 布局: s\PYGZus{}a[BM][BK]=[128][16](A row\PYGZhy{}major), s\PYGZus{}b[BN][BK]=[128][16](B\PYGZca{}T}
\PYG{+w}{  }\PYG{c+c1}{// row\PYGZhy{}major，即 B col\PYGZhy{}major [K×N] 在 smem 中按 B\PYGZca{}T[N×K] 存储)}
\PYG{+w}{  }\PYG{c+c1}{// 原始实现会按配置决定是否给 A/B 的 K 维加 PAD；尤其 B 在 TN 布局下常见会额外}
\PYG{+w}{  }\PYG{c+c1}{// 加 B\PYGZus{}PAD 来打散 bank 映射，避免按列访问时出现明显 bank conflict。这里先保留最简 PAD=0 版本。}
