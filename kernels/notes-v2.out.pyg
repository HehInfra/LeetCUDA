\PYG{+w}{  }\PYG{c+c1}{// 存储 4×4：每行 4 个元素连续 → 可用 float4 store（要求 N 为 4 的倍数以保证对齐）}
\PYG{+w}{  }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{store\PYGZus{}gmem\PYGZus{}c\PYGZus{}m}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{by}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{BM}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{comp\PYGZus{}smem\PYGZus{}a\PYGZus{}m\PYGZus{}base}\PYG{p}{;}
\PYG{+w}{  }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{store\PYGZus{}gmem\PYGZus{}c\PYGZus{}n}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{bx}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{BN}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{comp\PYGZus{}smem\PYGZus{}b\PYGZus{}n\PYGZus{}base}\PYG{p}{;}
\PYG{c+cp}{\PYGZsh{}pragma unroll}
\PYG{+w}{  }\PYG{k}{for}\PYG{+w}{ }\PYG{p}{(}\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{i}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{0}\PYG{p}{;}\PYG{+w}{ }\PYG{n}{i}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{+w}{ }\PYG{l+m+mi}{4}\PYG{p}{;}\PYG{+w}{ }\PYG{o}{++}\PYG{n}{i}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{    }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{store\PYGZus{}gmem\PYGZus{}c\PYGZus{}addr}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{store\PYGZus{}gmem\PYGZus{}c\PYGZus{}m}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{i}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{N}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{store\PYGZus{}gmem\PYGZus{}c\PYGZus{}n}\PYG{p}{;}
