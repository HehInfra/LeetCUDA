\PYG{c+c1}{// Elementwise Add + float4 向量化}
\PYG{c+c1}{// Grid:  ((N + 255) / 256, 1, 1)}
\PYG{c+c1}{// Block: (64, 1, 1)，block(64)×4(float4)=256 元素/block}
