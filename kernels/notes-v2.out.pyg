\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 5b\PYGZhy{}3: HGEMM WGMMA — m64n128k16 + TMA + Warp Specialization (Hopper)}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点（WGMMA vs MMA 对比）：}
\PYG{c+c1}{//   \PYGZhy{} MMA: warp 级（32 threads），同步执行}
\PYG{c+c1}{//   \PYGZhy{} WGMMA: warpgroup 级（128 threads = 4 warps），异步执行（fire\PYGZhy{}and\PYGZhy{}forget）}
\PYG{c+c1}{//   \PYGZhy{} m64n128k16: M=64, N=128, K=16 → 一次处理 64×128×16=131K 个乘加（MMA 的 32}
\PYG{c+c1}{//   倍）}
\PYG{c+c1}{//   \PYGZhy{} TMA (Tensor Memory Accelerator): 硬件 DMA，2D 寻址，零寄存器开销}
\PYG{c+c1}{//   \PYGZhy{} Warp Specialization: Producer 做 TMA，Consumer 做 WGMMA，通过 barrier}
\PYG{c+c1}{//   同步}
\PYG{c+c1}{//   \PYGZhy{} 128B swizzle: shared memory 的 128B swizzle 模式，避免 bank conflict}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} WGMMA 辅助函数 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+cp}{\PYGZsh{}define WGMMA\PYGZus{}FENCE() asm volatile(\PYGZdq{}wgmma.fence.sync.aligned;\PYGZbs{}n\PYGZdq{} ::: \PYGZdq{}memory\PYGZdq{})}
\PYG{c+cp}{\PYGZsh{}define WGMMA\PYGZus{}COMMIT\PYGZus{}GROUP()                                                   \PYGZbs{}}
\PYG{c+cp}{  asm volatile(\PYGZdq{}wgmma.commit\PYGZus{}group.sync.aligned;\PYGZbs{}n\PYGZdq{} ::: \PYGZdq{}memory\PYGZdq{})}
\PYG{c+cp}{\PYGZsh{}define WGMMA\PYGZus{}WAIT\PYGZus{}GROUP(n)                                                    \PYGZbs{}}
\PYG{c+cp}{  asm volatile(\PYGZdq{}wgmma.wait\PYGZus{}group.sync.aligned \PYGZpc{}0;\PYGZbs{}n\PYGZdq{} ::\PYGZdq{}n\PYGZdq{}(n) : \PYGZdq{}memory\PYGZdq{})}

\PYG{c+c1}{// Shared memory descriptor encode: 将 smem 地址编码为 WGMMA 可用的描述符}
\PYG{c+cp}{\PYGZsh{}define SMEM\PYGZus{}DESC\PYGZus{}ENCODE(x) ((((uint64\PYGZus{}t)(x)) \PYGZam{} 0x3FFFF) \PYGZgt{}\PYGZgt{} 0x4)}

\PYG{c+c1}{// make\PYGZus{}smem\PYGZus{}desc: 创建 WGMMA 的 shared memory 矩阵描述符}
\PYG{c+c1}{// 这里沿用原始 hgemm\PYGZus{}wgmma 实现里的描述符字段约定：}
\PYG{c+c1}{//   \PYGZhy{} base addr: 当前 shared memory tile 基址}
\PYG{c+c1}{//   \PYGZhy{} leading offset: 16 bytes = 8 个 half * 2B，对应 WGMMA 在 tile 内沿 minor}
\PYG{c+c1}{//     方向前进一次的 byte 步长}
\PYG{c+c1}{//   \PYGZhy{} stride offset: 1024 bytes = 64 * 8 * 2B，对应跨到下一条 major stripe 的 byte 步长}
\PYG{c+c1}{//   \PYGZhy{} bit 62: 打开 128B swizzle}
\PYG{c+c1}{// 这些字段是当前 WGMMA/TMA 布局下的实现常量，不要把它直接背成 BM/BK 的原始字节数公式。}
\PYG{n}{\PYGZus{}\PYGZus{}device\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{k+kr}{inline}\PYG{+w}{ }\PYG{k+kt}{uint64\PYGZus{}t}\PYG{+w}{ }\PYG{n}{make\PYGZus{}smem\PYGZus{}desc}\PYG{p}{(}\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{ptr}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{  }\PYG{k+kt}{uint32\PYGZus{}t}\PYG{+w}{ }\PYG{n}{addr}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{k}{static\PYGZus{}cast}\PYG{o}{\PYGZlt{}}\PYG{k+kt}{uint32\PYGZus{}t}\PYG{o}{\PYGZgt{}}\PYG{p}{(}\PYG{n}{\PYGZus{}\PYGZus{}cvta\PYGZus{}generic\PYGZus{}to\PYGZus{}shared}\PYG{p}{(}\PYG{n}{ptr}\PYG{p}{));}
\PYG{+w}{  }\PYG{k+kt}{uint64\PYGZus{}t}\PYG{+w}{ }\PYG{n}{desc}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mh}{0x0000000000000000}\PYG{p}{;}
\PYG{+w}{  }\PYG{n}{desc}\PYG{+w}{ }\PYG{o}{|=}\PYG{+w}{ }\PYG{n}{SMEM\PYGZus{}DESC\PYGZus{}ENCODE}\PYG{p}{(}\PYG{n}{addr}\PYG{p}{);}
\PYG{+w}{  }\PYG{n}{desc}\PYG{+w}{ }\PYG{o}{|=}\PYG{+w}{ }\PYG{n}{SMEM\PYGZus{}DESC\PYGZus{}ENCODE}\PYG{p}{((}\PYG{k+kt}{uint64\PYGZus{}t}\PYG{p}{)}\PYG{l+m+mi}{16}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{\PYGZlt{}\PYGZlt{}}\PYG{+w}{ }\PYG{l+m+mi}{16}\PYG{p}{;}\PYG{+w}{   }\PYG{c+c1}{// leading dim offset bytes}
\PYG{+w}{  }\PYG{n}{desc}\PYG{+w}{ }\PYG{o}{|=}\PYG{+w}{ }\PYG{n}{SMEM\PYGZus{}DESC\PYGZus{}ENCODE}\PYG{p}{((}\PYG{k+kt}{uint64\PYGZus{}t}\PYG{p}{)}\PYG{l+m+mi}{1024}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{\PYGZlt{}\PYGZlt{}}\PYG{+w}{ }\PYG{l+m+mi}{32}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// stride dim offset bytes}
\PYG{+w}{  }\PYG{n}{desc}\PYG{+w}{ }\PYG{o}{|=}\PYG{+w}{ }\PYG{l+m+mf}{1l}\PYG{n}{lu}\PYG{+w}{ }\PYG{o}{\PYGZlt{}\PYGZlt{}}\PYG{+w}{ }\PYG{l+m+mi}{62}\PYG{p}{;}\PYG{+w}{                             }\PYG{c+c1}{// 128B swizzle}
\PYG{+w}{  }\PYG{k}{return}\PYG{+w}{ }\PYG{n}{desc}\PYG{p}{;}
\PYG{p}{\PYGZcb{}}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} WGMMA PTX 指令宏 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// wgmma.mma\PYGZus{}async.sync.aligned.m64n128k16.f16.f16.f16}
\PYG{c+c1}{// m64n128k16: M=64, N=128, K=16}
\PYG{c+c1}{// f16.f16.f16: A=f16, B=f16, D=f16 (accumulation in f16)}
\PYG{c+c1}{// 每线程 32 个 uint32 输出：D=64×128=8192 half，warpgroup 128 线程分担，}
\PYG{c+c1}{// 每线程 64 half = 32 uint32}
\PYG{c+c1}{// descA/descB: shared memory 描述符（由 make\PYGZus{}smem\PYGZus{}desc 生成）}
