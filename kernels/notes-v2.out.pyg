\PYG{+w}{  }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{value}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}reduce\PYGZus{}max}\PYG{o}{\PYGZlt{}}\PYG{n}{WARP\PYGZus{}SIZE}\PYG{o}{\PYGZgt{}}\PYG{p}{(}\PYG{n}{val}\PYG{p}{);}
