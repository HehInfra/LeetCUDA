\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} Level 2: Safe Softmax（2\PYGZhy{}pass：先 max 再 exp，数值稳定）\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// 面试重点：为什么 Softmax 需要 Safe？}
\PYG{c+c1}{//   \PYGZhy{} expf 溢出阈值约 88.7：exp(88)≈1.65e38（接近 float32 上限 3.4e38），exp(89)≈4.5e38 已溢出为 inf}
\PYG{c+c1}{//   \PYGZhy{} 减去 max 后：exp(x \PYGZhy{} max) ≤ exp(0) = 1.0，永不超过 1}
\PYG{c+c1}{//   \PYGZhy{} 数学等价性：softmax(x) = softmax(x \PYGZhy{} c) 对任意常数 c 成立}
