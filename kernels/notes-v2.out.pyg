\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 7: Mat Transpose — 矩阵转置（Bank Conflict 专题）}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点（Bank Conflict 专题）：}
\PYG{c+c1}{//   \PYGZhy{} Shared memory 有 32 个 bank，每个 bank 4 bytes（32\PYGZhy{}bit）}
\PYG{c+c1}{//   \PYGZhy{} 同一 warp 的多个线程访问同一 bank 的不同地址 → bank conflict}
\PYG{c+c1}{//   \PYGZhy{} n\PYGZhy{}way bank conflict: n 个线程冲突 → 访问串行化为 n 次}
\PYG{c+c1}{//   \PYGZhy{} 解决方案：PAD（在每行末尾加 1 个元素，打破地址对齐）}
\PYG{c+c1}{//}
\PYG{c+c1}{// 转置的四步演进：}
\PYG{c+c1}{//   naive: 非合并写入（列优先写）→ 每个 warp 产生 32 次内存事务}
\PYG{c+c1}{//   shared: 写入 smem（行优先）→ 从 smem 读取（列优先）→ 合并写入 gmem}
\PYG{c+c1}{//   BCF:   smem 布局 [WARP\PYGZus{}SIZE\PYGZus{}S*4][WARP\PYGZus{}SIZE\PYGZus{}S+PAD] = [64][17]，PAD=1 加在第二维消除 bank conflict}
\PYG{c+c1}{//   merge\PYGZus{}write: 进一步将 4 次 separate store 合并为 1 次 float4 store}
\PYG{c+c1}{// 注：本文件仅实现 Level 1(naive) 与 Level 4(BCF+merge\PYGZus{}write)，Level 2/3 省略}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} Level 1: 基础版（2D 索引，合并读 + 非合并写）\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// 每个线程处理 1 个元素，block(16,16)}
\PYG{c+c1}{// 读：x 按行优先访问，warp 的 32 线程访问 32 个连续地址 → 合并读取 ✓}
\PYG{c+c1}{// 写：y 按列优先写入，32 线程跨 row 行分散 → 非合并写入 ✗（32 次内存事务）}
\PYG{c+c1}{// Grid:  ((col + 15) / 16, (row + 15) / 16, 1)，每线程 1 元素}
