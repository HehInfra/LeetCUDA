\PYG{c+c1}{// notes\PYGZhy{}v2.cu — CUDA Kernel 面试背题笔记}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{//}
\PYG{c+c1}{// 整理自 LeetCUDA 项目（https://github.com/xlite\PYGZhy{}dev/LeetCUDA），涵盖：}
\PYG{c+c1}{//   \PYGZhy{} 面试高频 CUDA kernel 的完整实现（共 37 个 kernel）}
\PYG{c+c1}{//   \PYGZhy{} 每类 kernel 附带详细的面试要点注释（WHY + HOW）}
\PYG{c+c1}{//   \PYGZhy{} 优化技术的递进式讲解（naive → tiling → vectorize → tensor core → ws）}
\PYG{c+c1}{//   \PYGZhy{} BLAS 语义：N=col\PYGZhy{}major(Normal), T=row\PYGZhy{}major(Transposed)}
\PYG{c+c1}{//}
\PYG{c+c1}{// 10 个 Phase 覆盖：}
\PYG{c+c1}{//   Phase 0 — 面试框架速查（GPU 架构 / Memory Hierarchy / Roofline / 优化清单）}
\PYG{c+c1}{//   Phase 1 — 基础原语：Warp Reduce / Block Reduce（含 broadcast 增强版）}
\PYG{c+c1}{//   Phase 2 — Elementwise：ReLU / Elementwise Add（基础 + float4 向量化）}
\PYG{c+c1}{//   Phase 3 — Softmax：naive → safe → online + RMS/Layer Norm}
\PYG{c+c1}{//   Phase 4 — GEMV：SGEMV K32/K128/K16 + HGEMV K32/K128/K16（warp\PYGZhy{}per\PYGZhy{}row）}
\PYG{c+c1}{//   Phase 5 — GEMM ★：SGEMM → HGEMM → MMA m16n8k16(TN布局) → WGMMA m64n128k16}
\PYG{c+c1}{//   Phase 6 — RoPE：旋转位置编码（Llama 风格 theta=10000）}
\PYG{c+c1}{//   Phase 7 — Mat Transpose：基础版 + BCF merge\PYGZus{}write 最佳版（Bank Conflict专题） }
\PYG{c+c1}{//   Phase 8 — 杂项：Dot Product / Block All Reduce / Histogram }
\PYG{c+c1}{//   Phase 9 — FlashAttention split\PYGZus{}q（FA\PYGZhy{}2, 含 online softmax + P@V 寄存器复用）}
\PYG{c+c1}{//}
\PYG{c+c1}{// =============================================================================}

\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 0: 面试框架速查（纯注释，面试开场必备的基础知识）}
\PYG{c+c1}{// =============================================================================}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} GPU 架构速查 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{//}
\PYG{c+c1}{// SM (Streaming Multiprocessor) 内部结构：}
\PYG{c+c1}{//   \PYGZhy{} Warp Scheduler ×4：每 SM 4 个 warp scheduler，每个每周期可发射 1 条指令}
\PYG{c+c1}{//   \PYGZhy{} Register File：每 SM 65536 × 32\PYGZhy{}bit = 256KB}
\PYG{c+c1}{//   \PYGZhy{} Shared Memory / L1：可配置，最大 shared memory \PYGZti{}228KB (Hopper)}
\PYG{c+c1}{//   \PYGZhy{} Tensor Cores：Hopper 每 SM 4 个；Blackwell 数量随型号/定义不同，建议以官方 ISV guide 为准}
\PYG{c+c1}{//   \PYGZhy{} Warp = 32 threads：最小调度单元，SIMT 执行模型}
\PYG{c+c1}{//}
\PYG{c+c1}{// Memory Hierarchy 带宽数量级（H100 参考）：}
\PYG{c+c1}{//   HBM3：        \PYGZti{}3.35 TB/s（理论），实际 \PYGZti{}2.5\PYGZhy{}3.0 TB/s}
\PYG{c+c1}{//   L2 Cache：    \PYGZti{}12 TB/s（50MB，跨 SM 共享）}
\PYG{c+c1}{//   L1/SMEM：     \PYGZti{}19 TB/s（每 SM \PYGZti{}228KB）}
\PYG{c+c1}{//   Register：    \PYGZti{}0 延迟，\PYGZti{}100+ TB/s 等效带宽}
\PYG{c+c1}{//}
\PYG{c+c1}{// 关键瓶颈判断：}
\PYG{c+c1}{//   Memory\PYGZhy{}bound：AI (Arithmetic Intensity) \PYGZlt{} 机器 FLOPS/带宽 比值}
\PYG{c+c1}{//   Compute\PYGZhy{}bound：AI 足够大，受限于计算吞吐}
\PYG{c+c1}{//   Latency\PYGZhy{}bound：线程不够多，无法隐藏内存延迟}
\PYG{c+c1}{//}
\PYG{c+c1}{// Occupancy 公式：}
\PYG{c+c1}{//   occupancy = active\PYGZus{}warps / max\PYGZus{}warps\PYGZus{}per\PYGZus{}SM}
\PYG{c+c1}{//   受三类资源分别取下限：每线程寄存器数 → threads/SM；每 block shared memory → blocks/SM；block 大小 → blocks/SM}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} 常见优化手段速查清单 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{//}
\PYG{c+c1}{// 1. Coalesced Memory Access（合并访问）}
\PYG{c+c1}{//    \PYGZhy{} 同一 warp 的线程访问连续的 128B 对齐地址 → 1 次内存事务}
\PYG{c+c1}{//    \PYGZhy{} 否则产生多次事务（最坏 32 次）}
\PYG{c+c1}{//}
\PYG{c+c1}{// 2. Tiling（分块）}
\PYG{c+c1}{//    \PYGZhy{} 将数据从 HBM 分块加载到 shared memory 复用，减少 HBM 访问}
\PYG{c+c1}{//    \PYGZhy{} GEMM: Block Tile (BM×BN) + K Tile (BK)}
\PYG{c+c1}{//}
\PYG{c+c1}{// 3. Vectorized Memory Access（向量化）}
\PYG{c+c1}{//    \PYGZhy{} 使用 float4/half2 等向量类型，减少 load/store 指令数}
\PYG{c+c1}{//    \PYGZhy{} float4 = 128\PYGZhy{}bit，单条指令加载 16 bytes}
\PYG{c+c1}{//}
\PYG{c+c1}{// 4. Thread Tile（寄存器分块）}
\PYG{c+c1}{//    \PYGZhy{} 每个线程计算多个输出元素（TM×TN），提高计算密度}
\PYG{c+c1}{//    \PYGZhy{} 减少线程总数，降低同步开销}
\PYG{c+c1}{//}
\PYG{c+c1}{// 5. Bank Conflict Avoidance}
\PYG{c+c1}{//    \PYGZhy{} Shared memory 有 32 banks × 4 bytes}
\PYG{c+c1}{//    \PYGZhy{} 同 warp 多线程访问同一 bank 的不同地址 → bank conflict → 串行化}
\PYG{c+c1}{//    \PYGZhy{} 解决方案：PAD（在每行末尾加 1 个元素打破对齐）}
\PYG{c+c1}{//}
\PYG{c+c1}{// 6. Pipeline / Double Buffering（流水线）}
\PYG{c+c1}{//    \PYGZhy{} cp.async 异步拷贝下一批数据时同时做当前批的计算}
\PYG{c+c1}{//    \PYGZhy{} Stage 数 = 2/3/4，权衡 shared memory 占用和延迟隐藏}
\PYG{c+c1}{//}
\PYG{c+c1}{// 7. Tensor Core（MMA / WGMMA）}
\PYG{c+c1}{//    \PYGZhy{} MMA m16n8k16 (Ampere): warp 级指令，单 warp 完成 16×8×16 的矩阵乘}
\PYG{c+c1}{//    \PYGZhy{} WGMMA m64n128k16 (Hopper): warpgroup 级指令（128 threads），异步执行}
\PYG{c+c1}{//}
\PYG{c+c1}{// 8. Warp Specialization（Hopper+）}
\PYG{c+c1}{//    \PYGZhy{} Producer warpgroup 做 TMA 数据搬运，Consumer warpgroup 做计算}
\PYG{c+c1}{//    \PYGZhy{} 通过 cuda::barrier 同步，完全解耦数据搬运和计算}
\PYG{c+c1}{//}
\PYG{c+c1}{// 9. TMA (Tensor Memory Accelerator, Hopper+)}
\PYG{c+c1}{//    \PYGZhy{} 硬件 DMA 引擎，支持 2D/3D 寻址，零寄存器开销}
\PYG{c+c1}{//    \PYGZhy{} 配合 cp.async.bulk 实现异步数据搬运}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} Roofline 分析公式 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{//}
\PYG{c+c1}{// AI (Arithmetic Intensity) = FLOPs / Bytes\PYGZus{}transferred}
\PYG{c+c1}{//}
\PYG{c+c1}{// GEMM (M=N=K=4096):}
\PYG{c+c1}{//   FLOPs = 2 × M × N × K = 2 × 4096³ ≈ 137 GFLOPS}
\PYG{c+c1}{//   Bytes  = (M×K + K×N + M×N) × sizeof(float) ≈ 200 MB}
\PYG{c+c1}{//   AI    ≈ 137G / 200M ≈ 685 FLOPS/Byte → compute\PYGZhy{}bound（远超 H100 ridge point：}
\PYG{c+c1}{//   FP16 TC ≈ 295:1，FP32 ≈ 20:1）}
\PYG{c+c1}{//}
\PYG{c+c1}{// GEMV (M=4096, K=4096):}
\PYG{c+c1}{//   FLOPs = 2 × M × K = 2 × 4096² ≈ 33 MFLOPS}
\PYG{c+c1}{//   Bytes = (M×K + K + M) × sizeof(float) ≈ 67 MB}
\PYG{c+c1}{//   AI    ≈ 33M / 67M ≈ 0.5 FLOPS/Byte → severely memory\PYGZhy{}bound}
\PYG{c+c1}{//}
\PYG{c+c1}{// Softmax (N=4096): AI ≈ (5×N) / (2×N×4) = 5/8 ≈ 0.625 FLOPS/Byte → memory\PYGZhy{}bound}

\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 1: 头文件 + 宏定义 + 基础原语（Warp Reduce / Block Reduce）}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点：}
\PYG{c+c1}{//   \PYGZhy{} warp\PYGZus{}reduce: 用 \PYGZus{}\PYGZus{}shfl\PYGZus{}xor\PYGZus{}sync 做蝶形归约，O(logN) 步，无需 shared}
\PYG{c+c1}{//   memory}
\PYG{c+c1}{//   \PYGZhy{} block\PYGZus{}reduce: 两级归约（warp → shared memory → warp0 broadcast），}
\PYG{c+c1}{//     注意最后必须 broadcast 回所有线程（\PYGZus{}\PYGZus{}shfl\PYGZus{}sync），否则只有 warp0 知道结果}
\PYG{c+c1}{//   \PYGZhy{} 为什么不用 \PYGZus{}\PYGZus{}shfl\PYGZus{}down\PYGZus{}sync？xor 模式所有线程做相同工作量，更均衡}

\PYG{c+cp}{\PYGZsh{}include}\PYG{+w}{ }\PYG{c+cpf}{\PYGZlt{}algorithm\PYGZgt{}}
\PYG{c+cp}{\PYGZsh{}include}\PYG{+w}{ }\PYG{c+cpf}{\PYGZlt{}cuda\PYGZus{}fp16.h\PYGZgt{}}
\PYG{c+cp}{\PYGZsh{}include}\PYG{+w}{ }\PYG{c+cpf}{\PYGZlt{}cuda\PYGZus{}runtime.h\PYGZgt{}}
\PYG{c+cp}{\PYGZsh{}include}\PYG{+w}{ }\PYG{c+cpf}{\PYGZlt{}float.h\PYGZgt{}}
\PYG{c+cp}{\PYGZsh{}include}\PYG{+w}{ }\PYG{c+cpf}{\PYGZlt{}stdio.h\PYGZgt{}}
\PYG{c+cp}{\PYGZsh{}include}\PYG{+w}{ }\PYG{c+cpf}{\PYGZlt{}stdlib.h\PYGZgt{}}

\PYG{c+cp}{\PYGZsh{}define WARP\PYGZus{}SIZE 32}
\PYG{c+cp}{\PYGZsh{}define INT4(value) (reinterpret\PYGZus{}cast\PYGZlt{}int4 *\PYGZgt{}(\PYGZam{}(value))[0])}
\PYG{c+cp}{\PYGZsh{}define FLOAT4(value) (reinterpret\PYGZus{}cast\PYGZlt{}float4 *\PYGZgt{}(\PYGZam{}(value))[0])}
\PYG{c+cp}{\PYGZsh{}define HALF2(value) (reinterpret\PYGZus{}cast\PYGZlt{}half2 *\PYGZgt{}(\PYGZam{}(value))[0])}

\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 1a: Warp Reduce（warp 内归约，纯寄存器操作，无需 shared memory）}
\PYG{c+c1}{// =============================================================================}

\PYG{c+c1}{// Warp Reduce Sum — generic (used by both FP32 and FP16 contexts)}
\PYG{c+c1}{// 使用 \PYGZus{}\PYGZus{}shfl\PYGZus{}xor\PYGZus{}sync 做蝶形归约（butterfly reduction）}
\PYG{c+c1}{// 复杂度 O(logN)，N=32 时仅需 5 步}
\PYG{c+c1}{// 模板参数：T=数据类型, kWarpSize=segment width（默认 32）}
\PYG{c+c1}{// kWarpSize 会作为 \PYGZus{}\PYGZus{}shfl\PYGZus{}xor\PYGZus{}sync 的第 4 个实参 width，限制 shuffle 在同一 segment 内}
\PYG{c+c1}{// 当 kWarpSize \PYGZlt{} 32（如 FA 中 kWarpSize=4）时，只有同 segment 的 lane 参与通信}
\PYG{c+c1}{//   蝶形归约示意（以 warpSize=8 为例，实际 warpSize=32 有 5 次迭代）：}
\PYG{c+c1}{//}
\PYG{c+c1}{//   初始: 每个 lane 持有自己的值 v0..v7}
\PYG{c+c1}{//   lane:  0    1    2    3    4    5    6    7}
\PYG{c+c1}{//   val:  v0   v1   v2   v3   v4   v5   v6   v7}
\PYG{c+c1}{//}
\PYG{c+c1}{//   mask=4 (第1次迭代，lane i 与 lane i\PYGZca{}4 交换并累加):}
\PYG{c+c1}{//          ┌──────────────┐}
\PYG{c+c1}{//   对:   (0,4) (1,5) (2,6) (3,7)}
\PYG{c+c1}{//}
\PYG{c+c1}{//   lane:  0    1    2    3    4    5    6    7}
\PYG{c+c1}{//   val: v0+v4 v1+v5 v2+v6 v3+v7 v4+v0 v5+v1 v6+v2 v7+v3}
\PYG{c+c1}{//}
\PYG{c+c1}{//   mask=2 (第2次迭代，lane i 与 lane i\PYGZca{}2 交换并累加):}
\PYG{c+c1}{//          ┌──────┐  ┌──────┐  ┌──────┐  ┌──────┐}
\PYG{c+c1}{//   对:   (0,2) (1,3) (4,6) (5,7)}
\PYG{c+c1}{//       ──── 前4个一组 ────   ──── 后4个一组 ────}
\PYG{c+c1}{//}
\PYG{c+c1}{//   lane:  0    1    2    3    4    5    6    7}
\PYG{c+c1}{//   val: Σ\PYGZob{}0,2,4,6\PYGZcb{} Σ\PYGZob{}1,3,5,7\PYGZcb{} Σ\PYGZob{}0,2,4,6\PYGZcb{} Σ\PYGZob{}1,3,5,7\PYGZcb{} Σ\PYGZob{}0,2,4,6\PYGZcb{} Σ\PYGZob{}1,3,5,7\PYGZcb{} Σ\PYGZob{}0,2,4,6\PYGZcb{} Σ\PYGZob{}1,3,5,7\PYGZcb{}   (每lane持有前一轮2个值的和再加本轮配对)}
\PYG{c+c1}{//        = v0+v2+v4+v6 ... (逐步归约)}
\PYG{c+c1}{//}
\PYG{c+c1}{//   mask=1 (第3次迭代，lane i 与 lane i\PYGZca{}1 交换并累加):}
\PYG{c+c1}{//          ┌──┐ ┌──┐ ┌──┐ ┌──┐ ┌──┐ ┌──┐ ┌──┐ ┌──┐}
\PYG{c+c1}{//   对:   (0,1)(2,3)(4,5)(6,7)}
\PYG{c+c1}{//}
\PYG{c+c1}{//   lane:  0    1    2    3    4    5    6    7}
\PYG{c+c1}{//   val:  Σall Σall Σall Σall Σall Σall Σall Σall  ← 所有 lane 拥有全归约结果！}
\PYG{c+c1}{//}
\PYG{c+c1}{//   mask=0: 循环终止，归约完成。}
\PYG{c+c1}{//}
\PYG{c+c1}{//   关键性质：}
\PYG{c+c1}{//   \PYGZhy{} XOR 配对是对称的：lane i 的配对对象是 lane i\PYGZca{}mask，而 (i\PYGZca{}mask)\PYGZca{}mask = i}
\PYG{c+c1}{//   \PYGZhy{} 每轮每个 lane 只和恰好 1 个其他 lane 通信（一对一，无冲突）}
\PYG{c+c1}{//   \PYGZhy{} 每轮信息传递距离减半：16→8→4→2→1（距离减半，信息翻倍）}
\PYG{c+c1}{//   \PYGZhy{} O(log₂ N) 步完成，无需 shared memory，纯寄存器操作}
\PYG{c+c1}{//   \PYGZhy{} \PYGZus{}\PYGZus{}shfl\PYGZus{}xor\PYGZus{}sync 第四个参数 kWarpSize 限制 segment width：}
\PYG{c+c1}{//     当 kWarpSize=4 时，只有同 segment(4个一组)内的 lane 参与 shuffle}
\PYG{k}{template}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{k}{typename}\PYG{+w}{ }\PYG{n+nc}{T}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{k+kt}{float}\PYG{p}{,}\PYG{+w}{ }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kWarpSize}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{o}{\PYGZgt{}}
\PYG{n}{\PYGZus{}\PYGZus{}device\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}forceinline\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{n}{T}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}reduce\PYGZus{}sum}\PYG{p}{(}\PYG{n}{T}\PYG{+w}{ }\PYG{n}{val}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{c+cp}{\PYGZsh{}pragma unroll}
\PYG{+w}{  }\PYG{k}{for}\PYG{+w}{ }\PYG{p}{(}\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{mask}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{kWarpSize}\PYG{+w}{ }\PYG{o}{\PYGZgt{}\PYGZgt{}}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{;}\PYG{+w}{ }\PYG{n}{mask}\PYG{+w}{ }\PYG{o}{\PYGZgt{}=}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{;}\PYG{+w}{ }\PYG{n}{mask}\PYG{+w}{ }\PYG{o}{\PYGZgt{}\PYGZgt{}=}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{    }\PYG{n}{val}\PYG{+w}{ }\PYG{o}{+=}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}shfl\PYGZus{}xor\PYGZus{}sync}\PYG{p}{(}\PYG{l+m+mh}{0xffffffff}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{val}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{mask}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{kWarpSize}\PYG{p}{);}
\PYG{+w}{  }\PYG{p}{\PYGZcb{}}
\PYG{+w}{  }\PYG{k}{return}\PYG{+w}{ }\PYG{n}{val}\PYG{p}{;}
\PYG{p}{\PYGZcb{}}

\PYG{c+c1}{// Warp Reduce Max — generic}
\PYG{k}{template}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{k}{typename}\PYG{+w}{ }\PYG{n+nc}{T}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{k+kt}{float}\PYG{p}{,}\PYG{+w}{ }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kWarpSize}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{o}{\PYGZgt{}}
\PYG{n}{\PYGZus{}\PYGZus{}device\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}forceinline\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{n}{T}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}reduce\PYGZus{}max}\PYG{p}{(}\PYG{n}{T}\PYG{+w}{ }\PYG{n}{val}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{c+cp}{\PYGZsh{}pragma unroll}
\PYG{+w}{  }\PYG{k}{for}\PYG{+w}{ }\PYG{p}{(}\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{mask}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{kWarpSize}\PYG{+w}{ }\PYG{o}{\PYGZgt{}\PYGZgt{}}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{;}\PYG{+w}{ }\PYG{n}{mask}\PYG{+w}{ }\PYG{o}{\PYGZgt{}=}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{;}\PYG{+w}{ }\PYG{n}{mask}\PYG{+w}{ }\PYG{o}{\PYGZgt{}\PYGZgt{}=}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{    }\PYG{n}{val}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{max}\PYG{p}{(}\PYG{n}{val}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}shfl\PYGZus{}xor\PYGZus{}sync}\PYG{p}{(}\PYG{l+m+mh}{0xffffffff}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{val}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{mask}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{kWarpSize}\PYG{p}{));}
\PYG{+w}{  }\PYG{p}{\PYGZcb{}}
