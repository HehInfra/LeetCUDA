\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// FlashAttention\PYGZhy{}2 Split\PYGZhy{}Q Kernel（完整实现）}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Q,K,V,O: [batch\PYGZus{}size, num\PYGZus{}heads, seq\PYGZus{}len, head\PYGZus{}dim], [B,H,N,d]}
\PYG{c+c1}{//}
\PYG{c+c1}{// Tile 设计（以 kHeadDim=64 为例）:}
\PYG{c+c1}{//   Br = kMmaAtomM * kMmaTileSeqLenQ * kWarpTileSeqLenQ = 16*4*1 = 64}
\PYG{c+c1}{//   Bc = kMmaAtomN * kMmaTileSeqLenK * kWarpTileSeqLenK = 8*1*8  = 64}
\PYG{c+c1}{//   Warp 布局: 4 warps, warp\PYGZus{}QP 0\PYGZti{}3 各处理 16 行, warp\PYGZus{}KV=0 共享 K}
\PYG{c+c1}{//}
\PYG{c+c1}{// 执行流程:}
\PYG{c+c1}{//   1) 预加载 Q[Br,d] 到 smem（只加载一次，split\PYGZhy{}Q 的核心优势）}
\PYG{c+c1}{//   2) 外循环: 沿 K seqlen 分块迭代 (Tc = seqlen/Bc)}
\PYG{c+c1}{//   3)   3a: cp.async 加载当前 V + 预加载下一个 K（多 stage pipeline）}
\PYG{c+c1}{//   4)   3b: Q@K\PYGZca{}T — 沿 head dim 内循环 → ldmatrix Q/K → HMMA16816}
\PYG{c+c1}{//   5)   3c: Online Safe Softmax — warp reduce max/row → exp(S*scale \PYGZhy{} max)}
\PYG{c+c1}{//         → 关键: 将 P 写回 R\PYGZus{}S 寄存器（替换 S），R\PYGZus{}S 现在存储 P matrix}
\PYG{c+c1}{//   6)   3d: P@V — 沿 V\PYGZus{}Bc 内循环 → ldmatrix V (transposed) → 直接用 R\PYGZus{}S 做 A}
\PYG{c+c1}{//         → 当前实现依赖同一组寄存器布局约定，避免为 P@V 额外重组 P fragment}
\PYG{c+c1}{//   7)   3e: Online rescaling — O\PYGZus{}new = exp(m\PYGZus{}old\PYGZhy{}m\PYGZus{}new)*O\PYGZus{}old + P@V}
\PYG{c+c1}{//   8) 最终 rescale: O\PYGZus{}final = (1/l\PYGZus{}final) * O\PYGZus{}final}
\PYG{c+c1}{//   9) Epilogue: warp shuffle + 128\PYGZhy{}bit collective store}

\PYG{k}{template}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kHeadDim}\PYG{p}{,}\PYG{+w}{          }\PYG{c+c1}{// head dim: 32, 64, 128}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kMmaAtomM}\PYG{p}{,}\PYG{+w}{         }\PYG{c+c1}{// 16 (MMA instruction M dimension)}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kMmaAtomN}\PYG{p}{,}\PYG{+w}{         }\PYG{c+c1}{// 8  (MMA instruction N dimension)}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kMmaAtomK}\PYG{p}{,}\PYG{+w}{         }\PYG{c+c1}{// 16 (MMA instruction K dimension)}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kMmaTileSeqLenQ}\PYG{p}{,}\PYG{+w}{   }\PYG{c+c1}{// MMA tiles along Q\PYGZsq{}s M dim, 4 → Br=16*4=64}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kMmaTileSeqLenK}\PYG{p}{,}\PYG{+w}{   }\PYG{c+c1}{// MMA tiles along K\PYGZsq{}s N dim, 1 → Bc basis=8}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kMmaTileSeqLenP}\PYG{p}{,}\PYG{+w}{   }\PYG{c+c1}{// MMA tiles for P@V M dim, must equal}
\PYG{+w}{                                 }\PYG{c+c1}{// kMmaTileSeqLenQ}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kMmaTileHeadDimV}\PYG{p}{,}\PYG{+w}{  }\PYG{c+c1}{// MMA tiles for P@V N dim (head dim direction)}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kWarpTileSeqLenQ}\PYG{p}{,}\PYG{+w}{  }\PYG{c+c1}{// warp tiles along Q\PYGZsq{}s M, 1 → Br per warp=16}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kWarpTileSeqLenK}\PYG{p}{,}\PYG{+w}{  }\PYG{c+c1}{// warp tiles along K\PYGZsq{}s N, 8 → Bc\PYGZus{}warp=8*8=64}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kWarpTileSeqLenP}\PYG{p}{,}\PYG{+w}{  }\PYG{c+c1}{// warp tiles for P@V M dim, 1}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kWarpTileHeadDimV}\PYG{p}{,}\PYG{+w}{ }\PYG{c+c1}{// warp tiles for P@V N dim,}
\PYG{+w}{                                 }\PYG{c+c1}{// kHeadDim/(8*kMmaTileHeadDimV)}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kStage}\PYG{p}{,}\PYG{+w}{            }\PYG{c+c1}{// pipeline stages for K: 1 or 2}
\PYG{+w}{    }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kPad}\PYG{o}{\PYGZgt{}}\PYG{+w}{              }\PYG{c+c1}{// padding for bank conflict avoidance}
\PYG{n}{\PYGZus{}\PYGZus{}global\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{k+kt}{void}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}launch\PYGZus{}bounds\PYGZus{}\PYGZus{}}\PYG{p}{(}\PYG{n}{WARP\PYGZus{}SIZE}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{kMmaTileSeqLenQ}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{kMmaTileSeqLenK}\PYG{p}{)}
\PYG{+w}{    }\PYG{n}{flash\PYGZus{}attn\PYGZus{}mma\PYGZus{}stages\PYGZus{}split\PYGZus{}q}\PYG{p}{(}\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{Q}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{K}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{V}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{half}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{O}\PYG{p}{,}
\PYG{+w}{                                  }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{QKV\PYGZus{}seqlen}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{QKV\PYGZus{}head}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}

\PYG{+w}{  }\PYG{c+c1}{// Tile dimensions}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{Br}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{kMmaAtomM}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{kMmaTileSeqLenQ}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{kWarpTileSeqLenQ}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 64}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{Bc}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{kMmaAtomN}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{kMmaTileSeqLenK}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{kWarpTileSeqLenK}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 64}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{kNumThreads}\PYG{+w}{ }\PYG{o}{=}
\PYG{+w}{      }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{kMmaTileSeqLenQ}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{kMmaTileSeqLenK}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 128}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{Tc}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{QKV\PYGZus{}seqlen}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{Bc}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{n}{Bc}\PYG{p}{;}
\PYG{+w}{  }\PYG{c+c1}{// 原始实现默认 seqlen 与 Bc 对齐；最后一个不完整 tile 需要额外 pad/边界处理。}
\PYG{+w}{  }\PYG{c+c1}{// 这里保留 ceil 写法是为了说明 tile 划分方式，不等于当前实现已经完整处理了尾 tile。}
\PYG{+w}{  }\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{scale}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mf}{1.0f}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{n}{sqrtf}\PYG{p}{((}\PYG{k+kt}{float}\PYG{p}{)}\PYG{n}{kHeadDim}\PYG{p}{);}

