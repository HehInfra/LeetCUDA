\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 2: Elementwise Ops（逐元素操作，演示 coalesced access + vectorize）}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点：}
\PYG{c+c1}{//   \PYGZhy{} 逐元素操作是最简单的 kernel，核心考点是 memory coalescing}
\PYG{c+c1}{//   \PYGZhy{} float4 向量化可将内存事务数减为 1/4，大幅提升 bandwidth utilization}
\PYG{c+c1}{//   \PYGZhy{} grid/block 维度设计：grid(N/threads), block(threads)，一维即可}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} ReLU: y = max(0, x) \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// Grid:  ((N + 255) / 256, 1, 1)}
\PYG{c+c1}{// Block: (256, 1, 1)}
\PYG{c+c1}{// source: LeetCUDA/kernels/relu/relu.cu}
\PYG{n}{\PYGZus{}\PYGZus{}global\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{k+kt}{void}\PYG{+w}{ }\PYG{n}{relu}\PYG{p}{(}\PYG{k+kt}{float}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{x}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{y}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{N}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{  }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{idx}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{blockIdx}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{blockDim}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{threadIdx}\PYG{p}{.}\PYG{n}{x}\PYG{p}{;}
\PYG{+w}{  }\PYG{k}{if}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{idx}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{+w}{ }\PYG{n}{N}\PYG{p}{)}
\PYG{+w}{    }\PYG{n}{y}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{fmaxf}\PYG{p}{(}\PYG{l+m+mf}{0.0f}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{x}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{]);}
\PYG{p}{\PYGZcb{}}

\PYG{c+c1}{// ReLU + float4 向量化：每个线程处理 4 个元素，减少 75\PYGZpc{} 的 load/store 指令}
\PYG{c+c1}{// block(64)×4(float4)=256 元素/block，与基础版吞吐相同}
\PYG{c+c1}{// Grid:  ((N + 255) / 256, 1, 1)}
\PYG{c+c1}{// Block: (64, 1, 1)}
\PYG{c+c1}{// 注意：该版本默认地址满足 float4 对齐；最适合 N 按 4 对齐的场景}
\PYG{c+c1}{// source: LeetCUDA/kernels/relu/relu.cu}
\PYG{n}{\PYGZus{}\PYGZus{}global\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{k+kt}{void}\PYG{+w}{ }\PYG{n}{relu\PYGZus{}vec4}\PYG{p}{(}\PYG{k+kt}{float}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{x}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{o}{*}\PYG{n}{y}\PYG{p}{,}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{N}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{  }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{idx}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{blockIdx}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{blockDim}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{threadIdx}\PYG{p}{.}\PYG{n}{x}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{l+m+mi}{4}\PYG{p}{;}
\PYG{+w}{  }\PYG{k}{if}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{idx}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{+w}{ }\PYG{n}{N}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{    }\PYG{n}{float4}\PYG{+w}{ }\PYG{n}{reg\PYGZus{}x}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{FLOAT4}\PYG{p}{(}\PYG{n}{x}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{]);}\PYG{+w}{ }\PYG{c+c1}{// 单条 128\PYGZhy{}bit load}
\PYG{+w}{    }\PYG{n}{float4}\PYG{+w}{ }\PYG{n}{reg\PYGZus{}y}\PYG{p}{;}
\PYG{+w}{    }\PYG{n}{reg\PYGZus{}y}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{fmaxf}\PYG{p}{(}\PYG{l+m+mf}{0.0f}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{reg\PYGZus{}x}\PYG{p}{.}\PYG{n}{x}\PYG{p}{);}
\PYG{+w}{    }\PYG{n}{reg\PYGZus{}y}\PYG{p}{.}\PYG{n}{y}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{fmaxf}\PYG{p}{(}\PYG{l+m+mf}{0.0f}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{reg\PYGZus{}x}\PYG{p}{.}\PYG{n}{y}\PYG{p}{);}
\PYG{+w}{    }\PYG{n}{reg\PYGZus{}y}\PYG{p}{.}\PYG{n}{z}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{fmaxf}\PYG{p}{(}\PYG{l+m+mf}{0.0f}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{reg\PYGZus{}x}\PYG{p}{.}\PYG{n}{z}\PYG{p}{);}
\PYG{+w}{    }\PYG{n}{reg\PYGZus{}y}\PYG{p}{.}\PYG{n}{w}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{fmaxf}\PYG{p}{(}\PYG{l+m+mf}{0.0f}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{reg\PYGZus{}x}\PYG{p}{.}\PYG{n}{w}\PYG{p}{);}
\PYG{+w}{    }\PYG{n}{FLOAT4}\PYG{p}{(}\PYG{n}{y}\PYG{p}{[}\PYG{n}{idx}\PYG{p}{])}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{reg\PYGZus{}y}\PYG{p}{;}\PYG{+w}{ }\PYG{c+c1}{// 单条 128\PYGZhy{}bit store}
\PYG{+w}{  }\PYG{p}{\PYGZcb{}}
\PYG{p}{\PYGZcb{}}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} Elementwise Add: c = a + b \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// Grid:  ((N + 255) / 256, 1, 1)}
\PYG{c+c1}{// Block: (256, 1, 1)}
