\PYG{+w}{  }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{out1}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{x1}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{cos\PYGZus{}v}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{+w}{ }\PYG{n}{x2}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{sin\PYGZus{}v}\PYG{p}{;}
\PYG{+w}{  }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{out2}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{x1}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{sin\PYGZus{}v}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{x2}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{n}{cos\PYGZus{}v}\PYG{p}{;}
\PYG{+w}{  }\PYG{n}{out}\PYG{p}{[}\PYG{n}{idx}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{l+m+mi}{2}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{out1}\PYG{p}{;}
\PYG{+w}{  }\PYG{n}{out}\PYG{p}{[}\PYG{n}{idx}\PYG{+w}{ }\PYG{o}{*}\PYG{+w}{ }\PYG{l+m+mi}{2}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{out2}\PYG{p}{;}
