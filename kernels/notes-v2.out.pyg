\PYG{c+c1}{// Grid:  ((N + 31) / 32, (M + 31) / 32, 1)}
\PYG{c+c1}{// Block: (32, 32, 1), 1024 线程}
\PYG{c+c1}{// source: LeetCUDA/kernels/sgemm/sgemm.cu}
