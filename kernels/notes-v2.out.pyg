\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 5b: HGEMM — Tensor Core 路径（MMA m16n8k16 + WGMMA m64n128k16）}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点：}
\PYG{c+c1}{//   \PYGZhy{} MMA (Matrix Multiply\PYGZhy{}Accumulate): Ampere+ 的 Tensor Core 指令}
\PYG{c+c1}{//   \PYGZhy{} m16n8k16 含义：M=16, N=8, K=16 的矩阵乘，结果 [16×8] = [16×16]×[16×8]}
\PYG{c+c1}{//   \PYGZhy{} ldmatrix: 从 shared memory 加载 16×16 的矩阵片段到寄存器（4 条 32\PYGZhy{}bit}
\PYG{c+c1}{//   寄存器）}
\PYG{c+c1}{//   \PYGZhy{} Multistage Pipeline: s2/s3/s4 个 stage，用 cp.async 异步加载下一批数据}
\PYG{c+c1}{//   \PYGZhy{} Block Swizzle: 在 grid 维度做 swizzle，改善 L2 cache locality}
\PYG{c+c1}{//}
\PYG{c+c1}{// ★ TN 布局详解（面试高频考点）：}
\PYG{c+c1}{//   TN 命名约定：来自 BLAS 的 op(A) × op(B) 语义}
\PYG{c+c1}{//     BLAS 源自 Fortran，默认列优先（column\PYGZhy{}major）存储}
\PYG{c+c1}{//     N = Normal（列优先，BLAS 原生格式）}
\PYG{c+c1}{//     T = Transposed（行优先，相对 BLAS 来说是\PYGZdq{}转置过的\PYGZdq{}）}
\PYG{c+c1}{//     第一个字母 → A 的 op，第二个字母 → B 的 op}
\PYG{c+c1}{//     所以 TN 表示：A 是行优先（相对 BLAS=Transposed），B 是列优先（相对}
\PYG{c+c1}{//     BLAS=Normal） 即：C = op(A) × op(B) = A\PYGZca{}T × B? 不对！ 在 row\PYGZhy{}major}
\PYG{c+c1}{//     视角下：TN = A row\PYGZhy{}major [M×K], B\PYGZca{}T row\PYGZhy{}major [N×K]（等价于 B col\PYGZhy{}major [K×N]） 在 cuBLAS}
\PYG{c+c1}{//     调用中：cublasGemmEx(..., CUBLAS\PYGZus{}OP\PYGZus{}T, CUBLAS\PYGZus{}OP\PYGZus{}N, ...)}
\PYG{c+c1}{//       T on A: BLAS 把 row\PYGZhy{}major 的 A 视为 A\PYGZca{}T，传 T 表示\PYGZdq{}转置回去\PYGZdq{}}
\PYG{c+c1}{//       N on B: B 已经是 BLAS 原生的 col\PYGZhy{}major，无需转置}
\PYG{c+c1}{//}
\PYG{c+c1}{//   记忆口诀：TN = A行(T) B列(N)，第一字母 A 第二字母 B}
\PYG{c+c1}{//     T = row\PYGZhy{}major（行优先，对 BLAS 来说是 transposed）}
\PYG{c+c1}{//     N = col\PYGZhy{}major（列优先，BLAS native = normal）}
\PYG{c+c1}{//}
\PYG{c+c1}{//   LeetCUDA \PYGZus{}nn 布局对比（A/B 均 row\PYGZhy{}major 自然存储）: C[M×N] = A[M×K] × B[K×N]}
\PYG{c+c1}{//     \PYGZhy{} A: row\PYGZhy{}major [M, K], B: row\PYGZhy{}major [K, N]}
\PYG{c+c1}{//     \PYGZhy{} 按 N=col\PYGZhy{}major/T=row\PYGZhy{}major 约定，二者 BLAS 视角均为 T → cuBLAS 等效 (T,T)}
\PYG{c+c1}{//     \PYGZhy{} 问题：ldmatrix 默认加载 col\PYGZhy{}major，B 是 row\PYGZhy{}major 需要 .trans}
\PYG{c+c1}{//}
\PYG{c+c1}{//   TN 布局: C[M×N] = A[M×K] × B[K×N]，B 以 B\PYGZca{}T=[N×K] row\PYGZhy{}major 存储（A 行优先，B 列优先）}
\PYG{c+c1}{//     \PYGZhy{} A [M×K]: row\PYGZhy{}major → 全局索引 A[m*K + k]，smem s\PYGZus{}a[BM][BK]}
\PYG{c+c1}{//     \PYGZhy{} B\PYGZca{}T [N×K]: row\PYGZhy{}major → 全局索引 B[n*K+k] 即访问原 B 元素 (k,n)（⚠ 内维连续的是 K）}
\PYG{c+c1}{//     \PYGZhy{} 优势：B\PYGZca{}T 已是 row\PYGZhy{}major，ldmatrix 无需 .trans，天然匹配 MMA row.col}
\PYG{c+c1}{//   MMA 指令: mma.sync.aligned.m16n8k16.row.col}
\PYG{c+c1}{//     \PYGZhy{} row.col: A 输入 row\PYGZhy{}major，B 输入 col\PYGZhy{}major → 与 TN 布局天然匹配}
\PYG{c+c1}{//}
\PYG{c+c1}{// WGMMA (Warp Group MMA, Hopper+):}
\PYG{c+c1}{//   \PYGZhy{} warpgroup 级指令（128 threads = 4 warps），异步执行}
\PYG{c+c1}{//   \PYGZhy{} m64n128k16: 一次处理 64×128×16 的矩阵乘（总 tile 量 131072，是 MMA m16n8k16 的 64 倍）}
\PYG{c+c1}{//   \PYGZhy{} Warp Specialization: Producer(128 threads) 做 TMA 搬运, Consumer(128}
\PYG{c+c1}{//   threads) 做计算}
\PYG{c+c1}{//   \PYGZhy{} TMA: 硬件 DMA，\PYGZti{}零寄存器开销，支持 1D\PYGZti{}5D 寻址}

\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 5b\PYGZhy{}1: MMA PTX 宏定义}
\PYG{c+c1}{// =============================================================================}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} gmem → smem: cp.async \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+cp}{\PYGZsh{}define CP\PYGZus{}ASYNC\PYGZus{}COMMIT\PYGZus{}GROUP() asm volatile(\PYGZdq{}cp.async.commit\PYGZus{}group;\PYGZbs{}n\PYGZdq{} ::)}
\PYG{c+cp}{\PYGZsh{}define CP\PYGZus{}ASYNC\PYGZus{}WAIT\PYGZus{}ALL() asm volatile(\PYGZdq{}cp.async.wait\PYGZus{}all;\PYGZbs{}n\PYGZdq{} ::)}
\PYG{c+cp}{\PYGZsh{}define CP\PYGZus{}ASYNC\PYGZus{}WAIT\PYGZus{}GROUP(n)                                                 \PYGZbs{}}
\PYG{c+cp}{  asm volatile(\PYGZdq{}cp.async.wait\PYGZus{}group \PYGZpc{}0;\PYGZbs{}n\PYGZdq{} ::\PYGZdq{}n\PYGZdq{}(n))}

\PYG{c+c1}{// cp.async.cg: bypass L1, 写入 L2（适合 GEMM 中只读一次的数据）}
\PYG{c+c1}{// cp.async.ca: cache all, L1+L2（适合需要多次复用的数据）}
\PYG{c+c1}{// 注意：cg 只支持 16 bytes，ca 支持 4/8/16 bytes}
\PYG{c+cp}{\PYGZsh{}define CP\PYGZus{}ASYNC\PYGZus{}CG(dst, src, bytes)                                           \PYGZbs{}}
\PYG{c+cp}{  asm volatile(                                                                \PYGZbs{}}
\PYG{c+cp}{      \PYGZdq{}cp.async.cg.shared.global.L2::128B [\PYGZpc{}0], [\PYGZpc{}1], \PYGZpc{}2;\PYGZbs{}n\PYGZdq{} ::\PYGZdq{}r\PYGZdq{}(dst),       \PYGZbs{}}
\PYG{c+cp}{      \PYGZdq{}l\PYGZdq{}(src), \PYGZdq{}n\PYGZdq{}(bytes))}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} ldmatrix: smem → register（Tensor Core 专用）\PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// ldmatrix.sync.aligned.xN.m8n8.shared.b16}
\PYG{c+c1}{// 每次加载 8×8 的 half 矩阵片段到 1/2/4 条 32\PYGZhy{}bit 寄存器}
\PYG{c+c1}{// aligned: 要求 128\PYGZhy{}bit 对齐}
\PYG{c+c1}{// trans:  转置加载（用于 col\PYGZhy{}major 的 B 矩阵）}
\PYG{c+cp}{\PYGZsh{}define LDMATRIX\PYGZus{}X4(R0, R1, R2, R3, addr)                                      \PYGZbs{}}
\PYG{c+cp}{  asm volatile(                                                                \PYGZbs{}}
\PYG{c+cp}{      \PYGZdq{}ldmatrix.sync.aligned.x4.m8n8.shared.b16 \PYGZob{}\PYGZpc{}0, \PYGZpc{}1, \PYGZpc{}2, \PYGZpc{}3\PYGZcb{}, [\PYGZpc{}4];\PYGZbs{}n\PYGZdq{}     \PYGZbs{}}
\PYG{c+cp}{      : \PYGZdq{}=r\PYGZdq{}(R0), \PYGZdq{}=r\PYGZdq{}(R1), \PYGZdq{}=r\PYGZdq{}(R2), \PYGZdq{}=r\PYGZdq{}(R3)                                 \PYGZbs{}}
\PYG{c+cp}{      : \PYGZdq{}r\PYGZdq{}(addr))}

\PYG{c+cp}{\PYGZsh{}define LDMATRIX\PYGZus{}X2(R0, R1, addr)                                              \PYGZbs{}}
\PYG{c+cp}{  asm volatile(\PYGZdq{}ldmatrix.sync.aligned.x2.m8n8.shared.b16 \PYGZob{}\PYGZpc{}0, \PYGZpc{}1\PYGZcb{}, [\PYGZpc{}2];\PYGZbs{}n\PYGZdq{}    \PYGZbs{}}
\PYG{c+cp}{               : \PYGZdq{}=r\PYGZdq{}(R0), \PYGZdq{}=r\PYGZdq{}(R1)                                            \PYGZbs{}}
\PYG{c+cp}{               : \PYGZdq{}r\PYGZdq{}(addr))}

\PYG{c+c1}{// ldmatrix.x2.trans: 转置加载（用于 NN 布局中需要 col\PYGZhy{}major B 矩阵的场景）}
\PYG{c+c1}{// FA 中 V[Bc,d] 为 row\PYGZhy{}major，但 P@V 的 MMA 需要 col\PYGZhy{}major 的 B → 使用 trans}
\PYG{c+c1}{// 加载}
\PYG{c+cp}{\PYGZsh{}define LDMATRIX\PYGZus{}X2\PYGZus{}T(R0, R1, addr)                                            \PYGZbs{}}
\PYG{c+cp}{  asm volatile(                                                                \PYGZbs{}}
