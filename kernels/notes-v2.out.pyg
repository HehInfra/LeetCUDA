\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 1b: Block Reduce（block 内归约，两级：warp → shared memory → warp reduce）}
\PYG{c+c1}{// =============================================================================}

\PYG{c+c1}{// Block Reduce Sum — FP32（增强版，带 broadcast）}
\PYG{c+c1}{// 两级归约流程：}
\PYG{c+c1}{//   1. 每个 warp 内做 warp\PYGZus{}reduce\PYGZus{}sum → 得到每 warp 的一个值}
\PYG{c+c1}{//   2. warp leader (lane=0) 写入 shared memory}
\PYG{c+c1}{//   3. syncthreads 后，lane 0\PYGZti{}NUM\PYGZus{}WARPS\PYGZhy{}1 读取 shared memory}
\PYG{c+c1}{//   4. 所有 warp 内再做一次 warp\PYGZus{}reduce\PYGZlt{}NUM\PYGZus{}WARPS\PYGZgt{} → 得到最终结果}
\PYG{c+c1}{//   5. \PYGZus{}\PYGZus{}shfl\PYGZus{}sync broadcast 到所有线程（关键！否则每个warp只有lane\PYGZlt{}NUM\PYGZus{}WARPS 知道结果）}
\PYG{k}{template}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{NUM\PYGZus{}THREADS}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{256}\PYG{o}{\PYGZgt{}}
\PYG{n}{\PYGZus{}\PYGZus{}device\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{block\PYGZus{}reduce\PYGZus{}sum}\PYG{p}{(}\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{val}\PYG{p}{)}\PYG{+w}{ }\PYG{p}{\PYGZob{}}
\PYG{+w}{  }\PYG{k}{constexpr}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{NUM\PYGZus{}WARPS}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{NUM\PYGZus{}THREADS}\PYG{+w}{ }\PYG{o}{+}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{+w}{ }\PYG{l+m+mi}{1}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{p}{;}
\PYG{+w}{  }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{warp}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{threadIdx}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{/}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{p}{;}
\PYG{+w}{  }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{lane}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{threadIdx}\PYG{p}{.}\PYG{n}{x}\PYG{+w}{ }\PYG{o}{\PYGZpc{}}\PYG{+w}{ }\PYG{n}{WARP\PYGZus{}SIZE}\PYG{p}{;}
\PYG{+w}{  }\PYG{k}{static}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}shared\PYGZus{}\PYGZus{}}\PYG{+w}{ }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{shared}\PYG{p}{[}\PYG{n}{NUM\PYGZus{}WARPS}\PYG{p}{];}

\PYG{+w}{  }\PYG{k+kt}{float}\PYG{+w}{ }\PYG{n}{value}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}reduce\PYGZus{}sum}\PYG{o}{\PYGZlt{}}\PYG{n}{WARP\PYGZus{}SIZE}\PYG{o}{\PYGZgt{}}\PYG{p}{(}\PYG{n}{val}\PYG{p}{);}
\PYG{+w}{  }\PYG{k}{if}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{lane}\PYG{+w}{ }\PYG{o}{==}\PYG{+w}{ }\PYG{l+m+mi}{0}\PYG{p}{)}
\PYG{+w}{    }\PYG{n}{shared}\PYG{p}{[}\PYG{n}{warp}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{value}\PYG{p}{;}
\PYG{+w}{  }\PYG{n}{\PYGZus{}\PYGZus{}syncthreads}\PYG{p}{();}
\PYG{+w}{  }\PYG{n}{value}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{p}{(}\PYG{n}{lane}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{+w}{ }\PYG{n}{NUM\PYGZus{}WARPS}\PYG{p}{)}\PYG{+w}{ }\PYG{o}{?}\PYG{+w}{ }\PYG{n}{shared}\PYG{p}{[}\PYG{n}{lane}\PYG{p}{]}\PYG{+w}{ }\PYG{o}{:}\PYG{+w}{ }\PYG{l+m+mf}{0.0f}\PYG{p}{;}
\PYG{+w}{  }\PYG{n}{value}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{warp\PYGZus{}reduce\PYGZus{}sum}\PYG{o}{\PYGZlt{}}\PYG{n}{NUM\PYGZus{}WARPS}\PYG{o}{\PYGZgt{}}\PYG{p}{(}\PYG{n}{value}\PYG{p}{);}
\PYG{+w}{  }\PYG{c+c1}{// 关键：broadcast 结果到所有线程，后续用 result}
\PYG{+w}{  }\PYG{c+c1}{// 做除法等操作时所有线程都能拿到}
\PYG{+w}{  }\PYG{n}{value}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{\PYGZus{}\PYGZus{}shfl\PYGZus{}sync}\PYG{p}{(}\PYG{l+m+mh}{0xffffffff}\PYG{p}{,}\PYG{+w}{ }\PYG{n}{value}\PYG{p}{,}\PYG{+w}{ }\PYG{l+m+mi}{0}\PYG{p}{,}\PYG{+w}{ }\PYG{l+m+mi}{32}\PYG{p}{);}
\PYG{+w}{  }\PYG{k}{return}\PYG{+w}{ }\PYG{n}{value}\PYG{p}{;}
\PYG{p}{\PYGZcb{}}

\PYG{c+c1}{// Block Reduce Max — FP32（增强版，带 broadcast）}
\PYG{k}{template}\PYG{+w}{ }\PYG{o}{\PYGZlt{}}\PYG{k}{const}\PYG{+w}{ }\PYG{k+kt}{int}\PYG{+w}{ }\PYG{n}{NUM\PYGZus{}THREADS}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+m+mi}{256}\PYG{o}{\PYGZgt{}}
