\PYG{c+c1}{// 核心递推公式：}
\PYG{c+c1}{//   m\PYGZus{}new = max(m\PYGZus{}old, x\PYGZus{}i)}
\PYG{c+c1}{//   d\PYGZus{}new = d\PYGZus{}old * exp(m\PYGZus{}old \PYGZhy{} m\PYGZus{}new) + exp(x\PYGZus{}i \PYGZhy{} m\PYGZus{}new)}
