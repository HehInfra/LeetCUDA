\PYG{c+c1}{//   \PYGZhy{} token\PYGZus{}idx = idx \PYGZpc{} N: token 内的维度对索引}
\PYG{c+c1}{//   \PYGZhy{} 输入 [seq\PYGZus{}len, hidden\PYGZus{}size], 输出同形状}

\PYG{c+c1}{// Grid:  ((seq\PYGZus{}len * N + 255) / 256, 1, 1)}
\PYG{c+c1}{// Block: (256, 1, 1)}
\PYG{c+c1}{// source: LeetCUDA/kernels/rope/rope.cu}
