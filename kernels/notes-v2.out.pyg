\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 5: GEMM — 矩阵矩阵乘（GPU 最重要的算子，面试核心考点）}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点（GEMM 优化五层金字塔）：}
\PYG{c+c1}{//   Level 1 — Tiling（分块 + shared memory）：将数据从 HBM 搬到 SMEM 复用}
\PYG{c+c1}{//   Level 2 — Thread Tile（寄存器分块）：每个线程计算 TM×TN}
\PYG{c+c1}{//   个元素，提高计算密度 Level 3 — Vectorize（向量化访存）：float4/half2，减少}
\PYG{c+c1}{//   load/store 指令数 Level 4 — Tensor Core（MMA}
\PYG{c+c1}{//   m16n8k16）：硬件矩阵乘单元，warp 级指令 Level 5 — Warp Specialization +}
\PYG{c+c1}{//   TMA（WGMMA m64n128k16）：Hopper 异步执行}
\PYG{c+c1}{//}
\PYG{c+c1}{// 计算密度递进：}
\PYG{c+c1}{//   Level 1: AI ≈ B\PYGZus{}K / (2×sizeof) ≈ 32/8 = 4 → 仍是 memory\PYGZhy{}bound}
\PYG{c+c1}{//   Level 2: AI ≈ TM×TN×B\PYGZus{}K / (2×sizeof) ≈ 8×8×8/8 = 64 → compute\PYGZhy{}bound}
\PYG{c+c1}{//   Level 4: Tensor Core 提供硬件加速的 256 FMA/cycle/warp → 大幅提升吞吐}

\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// Phase 5a: SGEMM + HGEMM（非 Tensor Core 路径）}
\PYG{c+c1}{// =============================================================================}

\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} Level 1: SGEMM — Block Tile 32×32 + K Tile 32 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// 最基础的 tiling 实现，演示 shared memory 的核心用法}
