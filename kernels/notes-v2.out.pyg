\PYG{c+c1}{// Phase 3: Reduce 类 Ops — Softmax / RMS Norm / Layer Norm}
\PYG{c+c1}{// =============================================================================}
\PYG{c+c1}{// 面试要点：}
\PYG{c+c1}{//   \PYGZhy{} Softmax 三种实现递进：naive（溢出）→ safe（2\PYGZhy{}pass，max 减法）→}
\PYG{c+c1}{//   online（1\PYGZhy{}pass，增量更新）}
\PYG{c+c1}{//   \PYGZhy{} Online Softmax 是 FlashAttention 的数学基础}
\PYG{c+c1}{//   \PYGZhy{} RMS Norm vs Layer Norm：RMS 只需 1 次 reduce，Layer Norm 需要 2 次（mean}
\PYG{c+c1}{//   + variance）}
