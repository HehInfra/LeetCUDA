\PYG{c+c1}{// \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{} Level 1+: SGEMM Vec4 — Block Tile 128×128 + K Tile 32 + Thread Tile 4×4 \PYGZhy{}\PYGZhy{}\PYGZhy{}\PYGZhy{}}
\PYG{c+c1}{// 在 Level 1 基础上引入两层优化：}
\PYG{c+c1}{//   1) float4 向量化加载：A/B 各用 1 条 128\PYGZhy{}bit load 取代 4 条 32\PYGZhy{}bit load}
\PYG{c+c1}{//   2) Thread Tile 4×4：每线程计算 16 个 C 元素，提升计算/访存比（AI 从}
\PYG{c+c1}{//   BK/2≈16 提升到 TM*TN*BK/2≈256），减少线程总数带来的同步开销}
\PYG{c+c1}{// C = A x B, C[M, N] = A[M, K] x B[K, N]，A/B 均 row\PYGZhy{}major}
\PYG{c+c1}{// BM=BN=128, BK=32, block(32, 32)=1024 线程，每线程负责 4×4=16 个 C 元素}
\PYG{c+c1}{//   1024 × 16 = 16384 = 128 × 128 ✓}
\PYG{c+c1}{//}
\PYG{c+c1}{// 线程到 4×4 tile 的映射（与加载映射解耦，独立计算更清晰）：}
\PYG{c+c1}{//   m\PYGZus{}tile = tid / 32 (0\PYGZti{}31)，每 tile 4 行 → 行 [m\PYGZus{}tile*4, m\PYGZus{}tile*4+3]，覆盖 0\PYGZti{}127}
\PYG{c+c1}{//   n\PYGZus{}tile = tid \PYGZpc{} 32 (0\PYGZti{}31)，每 tile 4 列 → 列 [n\PYGZus{}tile*4, n\PYGZus{}tile*4+3]，覆盖 0\PYGZti{}127}
\PYG{c+c1}{//}
\PYG{c+c1}{// 加载映射（每线程 4 个元素，float4）：}
\PYG{c+c1}{//   A[128][32]: a\PYGZus{}m = tid/8 (8 线程/行), a\PYGZus{}k = (tid\PYGZpc{}8)*4 (4 列/线程) → 8×4=32 列 ✓}
\PYG{c+c1}{//   B[32][128]: b\PYGZus{}k = tid/32 (32 线程/行), b\PYGZus{}n = (tid\PYGZpc{}32)*4 (4 列/线程) → 32×4=128 列 ✓}
\PYG{c+c1}{//   row\PYGZhy{}major 下 A[m][k..k+3] 与 B[k][n..n+3] 均连续 → float4 load 合法}
\PYG{c+c1}{//}
\PYG{c+c1}{// ⚠ Bank Conflict 提示（面试加分点）：}
\PYG{c+c1}{//   s\PYGZus{}b[32][128] 上 warp 内 32 线程按 stride=4 访问（tid\PYGZpc{}32 决定列 0,4,8,...,124）}
\PYG{c+c1}{//   → 每 4 个线程落同一 bank 不同地址 → 4\PYGZhy{}way bank conflict。生产代码可用}
\PYG{c+c1}{//   s\PYGZus{}b[BK][BN+1] PAD 打散，这里保持最简布局便于讲解。}
\PYG{c+c1}{//}
\PYG{c+c1}{// Grid:  ((N + 127) / 128, (M + 127) / 128, 1)}
\PYG{c+c1}{// Block: (32, 32, 1), 1024 线程}
\PYG{c+c1}{// 假设：M/N 为 128 的倍数，K 为 32 的倍数（与 Level 1 naive 版一致的边界约定）}
\PYG{c+c1}{// source: LeetCUDA/kernels/sgemm/sgemm.cu (vec4 variant)}
